# Server-only FastAPI origin. Never prefix this with NEXT_PUBLIC_.
FASTAPI_URL=http://127.0.0.1:8000

# Shared with FastAPI for signed client-IP forwarding. Use at least 32 random characters.
FASTAPI_BFF_SHARED_SECRET=replace-with-at-least-32-random-characters

# Session cookie lifetime for the rotating refresh token.
SESSION_REFRESH_MAX_AGE_SECONDS=604800
