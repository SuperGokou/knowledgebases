# Server-only FastAPI origin. Never prefix this with NEXT_PUBLIC_.
FASTAPI_URL=http://127.0.0.1:8000
# Optional for split-origin deployments. LAN deployments normally use the browser origin.
KB_PUBLIC_API_ORIGIN=

# Exact browser-facing origin. Required in production because forwarded
# Host/Proto headers are intentionally ignored for CSRF validation.
KB_PUBLIC_ORIGIN=http://localhost:3000

# Bounded BFF-to-FastAPI request deadline in milliseconds (1,000-120,000; default 60,000).
FASTAPI_REQUEST_TIMEOUT_MS=60000

# Shared with FastAPI for signed client-IP forwarding. Use at least 32 random characters.
FASTAPI_BFF_SHARED_SECRET=replace-with-at-least-32-random-characters

# Session cookie lifetime for the rotating refresh token.
SESSION_REFRESH_MAX_AGE_SECONDS=604800
