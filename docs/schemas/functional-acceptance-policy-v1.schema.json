{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:heyi:functional-acceptance-policy:v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy_id", "manifest_standard", "required_requirement_ids", "required_external_evidence_ids", "runners", "external_collectors"],
  "properties": {
    "schema_version": {"const": 1},
    "policy_id": {"type": "string", "minLength": 1},
    "manifest_standard": {"type": "string", "minLength": 1},
    "required_requirement_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^FUNC-[A-Z0-9-]+$"}},
    "required_external_evidence_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^EXT-[A-Z0-9-]+$"}},
    "runners": {"type": "object", "minProperties": 1},
    "external_collectors": {"type": "object", "minProperties": 1}
  }
}
