{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:heyi:knowledgebases:offline-runtime-evidence:v1",
  "title": "离线运行时验收证据 v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "status",
    "result",
    "runner",
    "collector",
    "collected_at",
    "challenge",
    "test_tenant",
    "target",
    "checks",
    "artifacts",
    "result_sha256",
    "attestation"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "evidence_id": {"const": "EXT-OFFLINE-RUNTIME-001"},
    "status": {"const": "complete"},
    "result": {"const": "passed"},
    "runner": {"const": "subprocess-v1"},
    "collector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {"const": "heyi-offline-runtime"},
        "version": {"const": "1.0.0"}
      }
    },
    "collected_at": {"type": "string", "format": "date-time"},
    "challenge": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{24,128}$"
    },
    "test_tenant": {
      "type": "string",
      "pattern": "^kb-acceptance-[a-z0-9-]{1,48}$"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "git_head",
        "content_fingerprint",
        "host_fingerprint",
        "project_name"
      ],
      "properties": {
        "git_head": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
        "content_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "host_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "project_name": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,62}$"
        }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "offline_network_isolation",
        "cold_start",
        "login",
        "rbac",
        "acl",
        "upload",
        "approval",
        "download",
        "question_answer",
        "restart_persistence",
        "network_recovery"
      ],
      "properties": {
        "offline_network_isolation": {"$ref": "#/$defs/check"},
        "cold_start": {"$ref": "#/$defs/check"},
        "login": {"$ref": "#/$defs/check"},
        "rbac": {"$ref": "#/$defs/check"},
        "acl": {"$ref": "#/$defs/check"},
        "upload": {"$ref": "#/$defs/check"},
        "approval": {"$ref": "#/$defs/check"},
        "download": {"$ref": "#/$defs/check"},
        "question_answer": {"$ref": "#/$defs/check"},
        "restart_persistence": {"$ref": "#/$defs/check"},
        "network_recovery": {"$ref": "#/$defs/check"}
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {"$ref": "#/$defs/artifact"}
    },
    "result_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "digest"],
      "properties": {
        "type": {"const": "sha256-chain-v1"},
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "artifact_ids"],
      "properties": {
        "status": {"const": "passed"},
        "artifact_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,128}$"}
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "sha256", "bytes"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,128}$"},
        "path": {"type": "string", "pattern": "^raw/[0-9]{3}-[A-Za-z0-9_.-]+\\.json$"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "bytes": {"type": "integer", "minimum": 1, "maximum": 1048576}
      }
    }
  }
}
