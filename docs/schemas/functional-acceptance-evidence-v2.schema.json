{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:heyi:knowledgebases:functional-acceptance-evidence:v2",
  "title": "企业知识库运行功能验收证据 v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "status",
    "collector",
    "target",
    "collected_at",
    "artifacts",
    "checks",
    "attestation"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "evidence_id": {"type": "string", "minLength": 1},
    "status": {"const": "complete"},
    "collector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["git_head", "content_fingerprint"],
      "properties": {
        "git_head": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
        "content_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "run_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]{8,80}$"}
      }
    },
    "collected_at": {"type": "string", "format": "date-time"},
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "sha256", "bytes"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "bytes": {"type": "integer", "minimum": 0, "maximum": 104857600}
        }
      }
    },
    "checks": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status", "artifact_ids"],
        "properties": {
          "status": {"const": "passed"},
          "artifact_ids": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "key_id", "challenge_id", "challenge_nonce", "signature"],
      "properties": {
        "type": {"const": "ed25519-challenge-v1"},
        "key_id": {"type": "string", "minLength": 1},
        "challenge_id": {"type": "string", "minLength": 16},
        "challenge_nonce": {"type": "string", "minLength": 32},
        "signature": {"type": "string", "minLength": 88, "maxLength": 88}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"evidence_id": {"const": "EXT-BROWSER-E2E-001"}}},
      "then": {"properties": {"target": {"required": ["run_id"]}}}
    }
  ]
}
