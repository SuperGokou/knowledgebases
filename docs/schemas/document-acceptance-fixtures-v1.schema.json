{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledgebases.invalid/schemas/document-acceptance-fixtures-v1.schema.json",
  "title": "Enterprise document acceptance fixtures v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fixture_set",
    "license",
    "content_origin",
    "network_required",
    "fixtures"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "fixture_set": { "const": "heyi-enterprise-document-acceptance-v1" },
    "license": { "const": "CC0-1.0" },
    "content_origin": { "const": "original-synthetic-test-data" },
    "network_required": { "const": false },
    "fixtures": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "extension",
          "relative_path",
          "token",
          "expected_source_locations",
          "generator",
          "sha256",
          "bytes"
        ],
        "properties": {
          "extension": {
            "enum": [".txt", ".csv", ".doc", ".docx", ".xls", ".xlsx", ".pdf", ".ppt", ".pptx"]
          },
          "relative_path": {
            "type": "string",
            "pattern": "^golden/[A-Za-z0-9._-]+$"
          },
          "token": {
            "type": "string",
            "pattern": "^KB-E2E-GOLDEN-[A-Z0-9]+-2026-[A-Z0-9]+$"
          },
          "expected_source_locations": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1, "maxLength": 200 }
          },
          "generator": { "enum": ["stdlib", "libreoffice"] },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "bytes": { "type": "integer", "minimum": 1, "maximum": 67108864 }
        }
      }
    }
  }
}
