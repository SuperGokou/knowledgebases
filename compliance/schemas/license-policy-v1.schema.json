{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledgebases.local/schemas/license-policy-v1.schema.json",
  "title": "Dependency license policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "allowed",
    "manual_review",
    "denied_substrings",
    "project_license_files"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "schemas/license-policy-v1.schema.json" },
    "schema_version": { "type": "integer", "const": 1 },
    "allowed": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
    "manual_review": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
    "denied_substrings": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
    "project_license_files": { "$ref": "#/$defs/nonEmptyUniqueStrings" }
  },
  "$defs": {
    "nonEmptyUniqueStrings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
