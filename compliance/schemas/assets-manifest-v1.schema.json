{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledgebases.local/schemas/assets-manifest-v1.schema.json",
  "title": "Repository asset provenance manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "inventory_roots",
    "asset_extensions",
    "embedded_text_extensions",
    "excluded_directories",
    "assets"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "schemas/assets-manifest-v1.schema.json" },
    "schema_version": { "type": "integer", "const": 1 },
    "inventory_roots": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
    "asset_extensions": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
    "embedded_text_extensions": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
    "excluded_directories": { "$ref": "#/$defs/nonEmptyUniqueStrings" },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "media_type",
          "bytes",
          "sha256",
          "asset_class",
          "provenance_status",
          "source_record"
        ],
        "oneOf": [
          { "required": ["path"] },
          { "required": ["source_path"] }
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "source_path": { "type": "string", "minLength": 1 },
          "media_type": { "type": "string", "pattern": "^[a-z0-9.+-]+/[a-z0-9.+-]+$" },
          "bytes": { "type": "integer", "minimum": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "asset_class": { "type": "string", "minLength": 1 },
          "provenance_status": { "enum": ["verified", "unverified"] },
          "source_record": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "nonEmptyUniqueStrings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
