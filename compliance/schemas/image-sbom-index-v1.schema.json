{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledgebases.local/schemas/image-sbom-index-v1.schema.json",
  "title": "Offline release image SBOM index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "release_id",
    "release_git_sha",
    "source_manifest_path",
    "source_manifest_sha256",
    "scanner",
    "images"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://knowledgebases.local/schemas/image-sbom-index-v1.schema.json"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "release_id": { "type": "string", "minLength": 1 },
    "release_git_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "source_manifest_path": { "type": "string", "minLength": 1 },
    "source_manifest_sha256": { "$ref": "#/$defs/sha256" },
    "scanner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "sha256"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "images": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/image" }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference",
        "manifest_digest",
        "config_id",
        "os",
        "architecture",
        "sbom_path",
        "sbom_sha256",
        "component_count"
      ],
      "properties": {
        "reference": { "type": "string", "minLength": 1 },
        "manifest_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "config_id": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "os": { "const": "linux" },
        "architecture": { "const": "amd64" },
        "sbom_path": { "type": "string", "minLength": 1 },
        "sbom_sha256": { "$ref": "#/$defs/sha256" },
        "component_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
