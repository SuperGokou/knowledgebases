{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledgebases.local/schemas/dependency-snapshot-v1.schema.json",
  "title": "Dependency snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "inputs", "sboms"],
  "properties": {
    "$schema": { "type": "string", "const": "schemas/dependency-snapshot-v1.schema.json" },
    "schema_version": { "type": "integer", "const": 1 },
    "inputs": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/boundFile" }
    },
    "sboms": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {
        "allOf": [
          { "$ref": "#/$defs/boundFile" },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "ecosystem",
              "path",
              "sha256",
              "format",
              "spec_version",
              "component_count",
              "dependency_count",
              "root"
            ],
            "properties": {
              "ecosystem": { "enum": ["python", "web"] },
              "path": { "$ref": "#/$defs/relativePath" },
              "sha256": { "$ref": "#/$defs/sha256" },
              "format": { "const": "CycloneDX" },
              "spec_version": { "const": "1.6" },
              "component_count": { "type": "integer", "minimum": 1 },
              "dependency_count": { "type": "integer", "minimum": 1 },
              "root": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "version"],
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "version": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        ]
      }
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "boundFile": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
