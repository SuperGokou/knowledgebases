{
	admin off
	auto_https disable_redirects
	default_sni {$KB_PUBLIC_HOST}
}

https://{$KB_PUBLIC_HOST}:8443 {
	tls internal
	encode zstd gzip
	reverse_proxy web:3000

	log {
		output stdout
		format json
	}
}

https://{$KB_PUBLIC_HOST}:9443 {
	tls internal
	reverse_proxy minio:9000

	log {
		output stdout
		format json
	}
}

