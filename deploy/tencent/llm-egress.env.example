# Store the real file outside every release directory, owned by root and mode 0600.
# This is the complete allowlist: do not copy the workspace .env to the server.
# Two independent providers are required because generated answers are reviewed by
# a second provider before they can be returned to a user.
KB_LLM_DEFAULT_PROVIDER=qwen
KB_DEEPSEEK_API_KEY=REPLACE_WITH_DEEPSEEK_API_KEY
KB_QWEN_API_KEY=REPLACE_WITH_QWEN_API_KEY
KB_MINIMAX_API_KEY=
