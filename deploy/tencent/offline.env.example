# Shared runtime settings and secrets. Copy to runtime.env as a non-symlinked,
# root-owned regular file outside every release directory.
# The preflight accepts mode 0600 or 0400 only and rejects every unknown key.
# Image references belong only in the per-release release.env file. Keeping
# mutable runtime secrets separate prevents a rollback from silently reusing
# the current release's application images.
# Use URL-safe random passwords (letters, numbers, underscore and hyphen only).
COMPOSE_PROJECT_NAME=heyi-kb-offline
KB_DATA_ROOT=/srv/heyi-knowledgebases-offline/data
KB_BIND_ADDRESS=10.0.0.10
KB_PUBLIC_HOST=10.0.0.10
KB_HTTPS_PORT=19443
KB_OBJECTS_HTTPS_PORT=19444
# Exact browser-facing origin used for CSRF validation. Keep this aligned with
# KB_PUBLIC_HOST and KB_HTTPS_PORT; forwarded Host/Proto headers are not trusted.
KB_PUBLIC_ORIGIN=https://10.0.0.10:19443

POSTGRES_DB=knowledge
POSTGRES_USER=knowledge
POSTGRES_PASSWORD=REPLACE_WITH_URL_SAFE_RANDOM_VALUE
POSTGRES_APP_USER=knowledge-runtime
POSTGRES_APP_PASSWORD=REPLACE_WITH_A_DIFFERENT_URL_SAFE_RANDOM_VALUE
REDIS_PASSWORD=REPLACE_WITH_URL_SAFE_RANDOM_VALUE

MINIO_ROOT_USER=knowledge-root
MINIO_ROOT_PASSWORD=REPLACE_WITH_URL_SAFE_RANDOM_VALUE
MINIO_APP_USER=knowledge-app
MINIO_APP_PASSWORD=REPLACE_WITH_URL_SAFE_RANDOM_VALUE
MINIO_REGION=us-east-1
MINIO_BUCKET=knowledge-base
MINIO_MULTIPART_MAX_AGE=2d
MINIO_MULTIPART_CLEANUP_INTERVAL_SECONDS=86400

KB_JWT_SECRET=REPLACE_WITH_AT_LEAST_64_RANDOM_CHARACTERS
KB_BFF_SHARED_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
KB_LLM_CREDENTIAL_ENCRYPTION_KEY=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
# Default-deny model networking. In strict_offline mode the gateway URL must be
# empty and the controlled-egress Compose profile must not be started. Enabling
# provider calls is an explicit change of both values plus the reviewed
# controlled-egress deployment operation; no provider is contacted by preflight.
KB_LLM_EGRESS_MODE=strict_offline
KB_LLM_EGRESS_GATEWAY_URL=
# Canonical comma-separated subset in this exact order: deepseek,qwen,minimax.
# Leave empty in strict_offline. controlled_gateway requires at least one;
# every approved route is probed before a release can be committed.
KB_LLM_EGRESS_APPROVED_PROVIDERS=

# Upgrade-only signed backup gate. Keep empty for first installation. Before an
# upgrade, point these at root-owned, non-symlink files produced by the reviewed
# backup + restore-drill ceremony.
KB_UPGRADE_BACKUP_EVIDENCE_PATH=
KB_UPGRADE_BACKUP_SIGNATURE_PATH=
KB_UPGRADE_BACKUP_PUBLIC_KEY_PATH=
# AES-256-GCM chat replay keyring. Store this file outside release directories,
# retain old versions until their replay TTL has elapsed, and only then remove them.
# Generate each value with: python -c "import base64,secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
KB_CHAT_REPLAY_ENCRYPTION_KEYS={"1":"REPLACE_WITH_32_BYTE_BASE64URL_KEY"}
KB_CHAT_REPLAY_ACTIVE_KEY_VERSION=1
KB_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# Required only for the one-time `--profile ops run --rm bootstrap` command.
# Clear this value immediately after the administrator is created.
KB_BOOTSTRAP_ADMIN_PASSWORD=REPLACE_WITH_A_UNIQUE_ADMIN_PASSWORD

# JSON arrays. KB_TRUSTED_HOSTS must be exactly [KB_PUBLIC_HOST, api].
# The internal api service name is required and the order is fixed.
KB_TRUSTED_HOSTS='["10.0.0.10","api"]'
KB_CORS_ORIGINS='[]'
KB_MULTIPART_THRESHOLD_BYTES=104857600
CLAMAV_DATABASE_MAX_AGE_SECONDS=604800
KB_MALWARE_SCAN_TIMEOUT_SECONDS=120
KB_MALWARE_SCAN_CHUNK_SIZE_BYTES=1048576
KB_MALWARE_SCAN_RECLAIM_SECONDS=300

# These are intentionally fixed by compose.offline.yml and must not be overridden:
# KB_DEPLOYMENT_PROFILE=isolated
# KB_DATABASE_URL=...@postgres:5432/...
# KB_REDIS_URL=...@redis:6379/0
# KB_S3_ENDPOINT_URL=http://minio:9000
# KB_PLATFORM_MAX_UPLOAD_BYTES=2147483648
# KB_MALWARE_SCAN_MAX_STREAM_BYTES=2147483648
# KB_STORAGE_CAPACITY_PROBE_PATH=/var/lib/kb-capacity
# KB_STORAGE_WARNING_PERCENT=70
# KB_STORAGE_BULK_STOP_PERCENT=80
# KB_STORAGE_REJECT_PERCENT=90
# KB_STORAGE_OBJECT_STOP_BYTES=180000000000
