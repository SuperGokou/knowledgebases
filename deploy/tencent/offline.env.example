# Copy to a root-owned file outside the release directory and chmod 0600.
# Use URL-safe random passwords (letters, numbers, underscore and hyphen only).
COMPOSE_PROJECT_NAME=heyi-kb-offline
KB_DATA_ROOT=/srv/heyi-knowledgebases-offline/data
KB_BIND_ADDRESS=0.0.0.0
KB_PUBLIC_HOST=10.0.0.10
KB_HTTPS_PORT=19443
KB_OBJECTS_HTTPS_PORT=19444

KB_API_IMAGE=heyi-kb-offline-api:local
KB_WEB_IMAGE=heyi-kb-offline-web:local

POSTGRES_DB=knowledge
POSTGRES_USER=knowledge
POSTGRES_PASSWORD=REPLACE_WITH_URL_SAFE_RANDOM_VALUE
POSTGRES_APP_USER=knowledge-runtime
POSTGRES_APP_PASSWORD=REPLACE_WITH_A_DIFFERENT_URL_SAFE_RANDOM_VALUE
REDIS_PASSWORD=REPLACE_WITH_URL_SAFE_RANDOM_VALUE

MINIO_ROOT_USER=knowledge-root
MINIO_ROOT_PASSWORD=REPLACE_WITH_URL_SAFE_RANDOM_VALUE
MINIO_APP_USER=knowledge-app
MINIO_APP_PASSWORD=REPLACE_WITH_URL_SAFE_RANDOM_VALUE
MINIO_REGION=us-east-1
MINIO_BUCKET=knowledge-base
MINIO_MULTIPART_MAX_AGE=2d
MINIO_MULTIPART_CLEANUP_INTERVAL_SECONDS=86400

KB_JWT_SECRET=REPLACE_WITH_AT_LEAST_64_RANDOM_CHARACTERS
KB_BFF_SHARED_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
KB_LLM_CREDENTIAL_ENCRYPTION_KEY=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
KB_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# Required only for the one-time `--profile ops run --rm bootstrap` command.
# Clear this value immediately after the administrator is created.
KB_BOOTSTRAP_ADMIN_PASSWORD=REPLACE_WITH_A_UNIQUE_ADMIN_PASSWORD

# JSON arrays. The host must match KB_PUBLIC_HOST.
KB_TRUSTED_HOSTS='["10.0.0.10"]'
KB_CORS_ORIGINS='[]'
KB_MULTIPART_THRESHOLD_BYTES=104857600

# These are intentionally fixed by compose.offline.yml and must not be overridden:
# KB_DEPLOYMENT_PROFILE=isolated
# KB_EXTERNAL_LLM_ENABLED=false
# KB_DATABASE_URL=...@postgres:5432/...
# KB_REDIS_URL=...@redis:6379/0
# KB_S3_ENDPOINT_URL=http://minio:9000
