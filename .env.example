# Copy this file to .env.kb, replace the secrets, then run `scripts/start.ps1`.
# Development values only: replace every password/secret for shared or production use.
COMPOSE_PROJECT_NAME=enterprise-kb
# Docker Desktop Buildx on Windows can fail when the workspace path contains non-ASCII text.
COMPOSE_BAKE=false

APP_PORT=8000
KB_ENVIRONMENT=development
KB_DEBUG=false
KB_JWT_SECRET=dev-only-replace-with-at-least-32-random-characters-0123456789
KB_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
KB_BOOTSTRAP_ADMIN_PASSWORD=DevOnly-Replace-This-Admin-Password-123!
KB_MULTIPART_THRESHOLD_BYTES=104857600

POSTGRES_DB=knowledge
POSTGRES_USER=knowledge
# Keep local Compose credentials URL-safe; production should inject a secret and encoded URL.
POSTGRES_PASSWORD=DevOnlyPostgresPassword123
POSTGRES_PORT=5432

REDIS_PASSWORD=DevOnlyRedisPassword123
REDIS_PORT=6379

MINIO_ROOT_USER=knowledge
MINIO_ROOT_PASSWORD=DevOnlyMinioPassword123
MINIO_APP_USER=knowledge-app
MINIO_APP_PASSWORD=DevOnlyMinioAppPassword123
MINIO_REGION=us-east-1
MINIO_BUCKET=knowledge-base
MINIO_CORS_ORIGIN=http://localhost:3000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
KB_S3_PUBLIC_ENDPOINT_URL=http://localhost:9000

# This must exceed the application's active upload-session window (24h by default).
MINIO_MULTIPART_MAX_AGE=2d
MINIO_MULTIPART_CLEANUP_INTERVAL_SECONDS=86400
