# Copy this file to .env.kb, replace the secrets, then run `scripts/start.ps1`.
# Development values only: replace every password/secret for shared or production use.
COMPOSE_PROJECT_NAME=enterprise-kb
# Docker Desktop Buildx on Windows can fail when the workspace path contains non-ASCII text.
COMPOSE_BAKE=false

APP_PORT=8000
KB_ENVIRONMENT=development
KB_DEBUG=false
# Use `isolated` only with the dedicated Tencent offline Compose profile.
KB_DEPLOYMENT_PROFILE=standard
# Fail closed by default. This mode is the only enable/disable source; the former
# KB_EXTERNAL_LLM_ENABLED variable is rejected to prevent contradictory settings.
# `direct` is for reviewed standard deployments only; isolated deployments may
# use `controlled_gateway` with the fixed internal URL.
KB_LLM_EGRESS_MODE=strict_offline
KB_LLM_EGRESS_GATEWAY_URL=
KB_JWT_SECRET=dev-only-replace-with-at-least-32-random-characters-0123456789
# Optional BFF-only HMAC secret; leave empty when no trusted BFF is used.
KB_BFF_SHARED_SECRET=
KB_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
KB_BOOTSTRAP_ADMIN_PASSWORD=DevOnly-Replace-This-Admin-Password-123!
KB_MULTIPART_THRESHOLD_BYTES=104857600
# Completed/unknown chat outcomes are retained for one day. A processing claim older
# than five minutes becomes terminal-unknown and is never executed again.
KB_CHAT_IDEMPOTENCY_TTL_SECONDS=86400
KB_CHAT_IDEMPOTENCY_PROCESSING_TIMEOUT_SECONDS=300
# Upper bound for canonical JSON and authenticated encrypted replay payloads.
KB_CHAT_IDEMPOTENCY_RESPONSE_MAX_BYTES=131072
KB_CHAT_IDEMPOTENCY_CLEANUP_BATCH_SIZE=1000
KB_CHAT_IDEMPOTENCY_CLEANUP_MAX_BATCHES=5
# Required before chat can execute. Values are 32 random bytes encoded as base64url.
# Keep old versions during rotation; new responses use only the active version.
# Generate each value with: python -c "import base64,secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
KB_CHAT_REPLAY_ENCRYPTION_KEYS={"1":"REPLACE_WITH_32_BYTE_BASE64URL_KEY"}
KB_CHAT_REPLAY_ACTIVE_KEY_VERSION=1

POSTGRES_DB=knowledge
POSTGRES_USER=knowledge
# Keep local Compose credentials URL-safe; production should inject a secret and encoded URL.
POSTGRES_PASSWORD=DevOnlyPostgresPassword123
POSTGRES_PORT=5432

REDIS_PASSWORD=DevOnlyRedisPassword123
REDIS_PORT=6379

MINIO_ROOT_USER=knowledge
MINIO_ROOT_PASSWORD=DevOnlyMinioPassword123
MINIO_APP_USER=knowledge-app
MINIO_APP_PASSWORD=DevOnlyMinioAppPassword123
MINIO_REGION=us-east-1
MINIO_BUCKET=knowledge-base
MINIO_CORS_ORIGIN=http://localhost:3000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
KB_S3_PUBLIC_ENDPOINT_URL=http://localhost:9000

# Optional OpenAI-compatible model providers for RAG and OKF v0.1 compilation.
# Configure credentials in the server/worker environment, never in the browser.
KB_LLM_DEFAULT_PROVIDER=deepseek
# Required before an administrator stores or rotates provider keys in the UI.
KB_LLM_CREDENTIAL_ENCRYPTION_KEY=
KB_DEEPSEEK_API_KEY=
KB_DEEPSEEK_BASE_URL=https://api.deepseek.com
KB_DEEPSEEK_MODEL=deepseek-v4-flash
KB_QWEN_API_KEY=
KB_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
KB_QWEN_MODEL=qwen-plus
# JSON array of exact Qwen workspace hosts. Wildcards are rejected.
KB_QWEN_ALLOWED_WORKSPACE_HOSTS=[]
KB_MINIMAX_API_KEY=
KB_MINIMAX_BASE_URL=https://api.minimax.io/v1
KB_MINIMAX_MODEL=MiniMax-M2.7
KB_OKF_SOURCE_MAX_BYTES=1000000
KB_OKF_CONVERSION_BATCH_SIZE=5
KB_OKF_CONVERSION_TIME_BUDGET_SECONDS=50

# This must exceed the application's active upload-session window (24h by default).
MINIO_MULTIPART_MAX_AGE=2d
MINIO_MULTIPART_CLEANUP_INTERVAL_SECONDS=86400
